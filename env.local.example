# Copy to `.env.local` (gitignored) and adjust values. Do not commit `.env.local`.

# HS256 secret for `Authorization: Bearer` (min 32 characters).
JWT_SECRET_KEY=replace_with_openssl_rand_hex_32_or_longer

# `0` = require JWT and/or X-API-Key when those are configured.
PUBLIC_API_ALLOW_ANONYMOUS=0

# Exact string clients must send as `X-API-Key`. Generate e.g. `openssl rand -hex 32`.
# Postman: set collection variable `apiKey` to this same string (no Bearer).
API_KEY=
